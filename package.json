{
  "name": "draw-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean",
    "dev:http": "turbo run dev --filter=http-backend",
    "dev:ws": "turbo run dev --filter=ws-backend",
    "dev:web": "turbo run dev --filter=web",
    "start:http": "turbo run start --filter=http-backend",
    "start:ws": "turbo run start --filter=ws-backend"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.6.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
